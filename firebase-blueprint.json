{
  "entities": {
    "Business": {
      "title": "Business",
      "description": "A business registered in the system",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID of the business" },
        "name": { "type": "string", "description": "Name of the business" },
        "ownerId": { "type": "string", "description": "UID of the business owner" },
        "googlePlaceId": { "type": "string", "description": "Google Maps Place ID" },
        "googleReviewUrl": { "type": "string", "description": "Direct link to Google Review page" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "qrCodeUrl": { "type": "string", "description": "URL for the QR code" },
        "address": { "type": "string", "description": "Business address" },
        "settings": {
          "type": "object",
          "properties": {
            "showName": { "type": "boolean", "description": "Show name field on review page" },
            "showPhone": { "type": "boolean", "description": "Show phone field on review page" }
          }
        }
      },
      "required": ["id", "name", "ownerId", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "A review submitted by a customer",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique ID of the review" },
        "businessId": { "type": "string", "description": "ID of the business being reviewed" },
        "rating": { "type": "number", "description": "Star rating (1-5)" },
        "comment": { "type": "string", "description": "Review text" },
        "aiGenerated": { "type": "boolean", "description": "Whether the review was generated by AI" },
        "customerName": { "type": "string", "description": "Name of the customer" },
        "customerPhone": { "type": "string", "description": "Phone number of the customer" },
        "reply": { "type": "string", "description": "Business owner's reply" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Submission timestamp" }
      },
      "required": ["id", "businessId", "rating", "createdAt"]
    },
    "User": {
      "title": "User",
      "description": "A user of the application (admin/business owner)",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "description": "User email" },
        "phoneNumber": { "type": "string", "description": "User phone number" },
        "displayName": { "type": "string", "description": "User full name" },
        "role": { "type": "string", "enum": ["super_admin", "owner"], "description": "User role" },
        "plan": { "type": "string", "enum": ["free", "silver", "gold"], "description": "Subscription plan" },
        "trialEndsAt": { "type": "string", "format": "date-time", "description": "Trial expiration timestamp" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Registration timestamp" }
      },
      "required": ["id", "email", "role", "plan", "trialEndsAt"]
    }
  },
  "firestore": {
    "/businesses/{businessId}": {
      "schema": "Business",
      "description": "Business records"
    },
    "/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Review records"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    }
  }
}
